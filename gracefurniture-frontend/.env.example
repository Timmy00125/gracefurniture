# ─────────────────────────────────────────────────────────────
# Grace Furniture — frontend env
# Copy to `.env` and fill in your values. All keys are exposed
# to the client (Vite prefixes them with VITE_), so for production
# proxy Gemini through a Cloud Function.
# ─────────────────────────────────────────────────────────────

# Firebase Web SDK (optional — app runs on mock data without it)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google AI Studio (Gemini 1.5 Flash) — optional
# Get a key at https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# Backend API base URL — leave blank to use mock data
# VITE_API_URL=http://localhost:3001
